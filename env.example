# -------------------------
# Database Configuration
# -------------------------
PSQL_DATABASE=myDayDB
PSQL_USER=postgres
PSQL_PASSWORD=your-db-password
PSQL_URL=jdbc:postgresql://localhost:5432/myDayDB

# -------------------------
# JWT Configuration
# -------------------------
JWT_SECRET_KEY=your-jwt-secret-key
JWT_EXPIRATION_MS=3600000

# -------------------------
# Server / CORS Configuration
# -------------------------
SERVER_URL=https://mydayapp.com
SERVER_IP=http://192.168.1.10
LOCALHOST_URL=http://localhost:8080
LOCAL_TEST_URL=http://127.0.0.1:5500

# -------------------------
# Mail Configuration
# -------------------------
MAIL_SENDER_SERVER=smtp.gmail.com
MAIL_SENDER_PORT=587
MAIL_USE_TLS=true
SUPPORT_EMAIL=your-support-email
SUPPORT_EMAIL_APP_PASSWORD=your-app-password